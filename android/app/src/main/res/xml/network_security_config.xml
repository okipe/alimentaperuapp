<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuración de seguridad de red para Alimenta Perú.

  En producción todas las comunicaciones deben ir por HTTPS.
  Esta configuración bloquea texto plano excepto en localhost
  (útil para el emulador en desarrollo).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- Permitir HTTP solo en localhost para pruebas locales -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>
</network-security-config>
