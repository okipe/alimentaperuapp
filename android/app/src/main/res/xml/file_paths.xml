<?xml version="1.0" encoding="utf-8"?>
<!--
  Rutas autorizadas para el FileProvider (compartir PDFs).
  Ref: https://developer.android.com/reference/androidx/core/content/FileProvider
-->
<paths>
    <!-- Directorio de caché interno (PDFs generados temporalmente) -->
    <cache-path name="cache" path="."/>

    <!-- Directorio externo de caché (impresión) -->
    <external-cache-path name="external_cache" path="."/>

    <!-- Directorio de archivos internos -->
    <files-path name="files" path="."/>
</paths>
